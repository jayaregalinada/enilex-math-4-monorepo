# Dependencies
node_modules/
.pnp.*

# Build output
dist/
build/
out/
*.tsbuildinfo

# Turborepo
.turbo/

# Test / coverage
coverage/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Environment & secrets — NEVER commit real values (see SECURITY.md).
# Only .env.example (placeholders) is tracked.
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
*.local

# Copyrighted source material must not be redistributed (see ADR / CONTRIBUTING).
*.pdf
lesson.pdf

# Audio assets are gitignored until each file has a CREDITS.md entry (ADR 0006).
# Once a track's source + licence are recorded, force-add it (git add -f) — or
# remove this guard once all committed music is properly credited.
apps/rounding-numbers/src/assets/music/*.mp3
apps/rounding-numbers/src/assets/music/*.ogg
apps/rounding-numbers/src/assets/music/*.m4a
apps/rounding-numbers/src/assets/music/*.wav

# Cleared tracks — owned, AI-generated with Treblo (see CREDITS.md). Allowed past
# the guard above so only credited, redistributable files can be committed.
# FesliyanStudios, Suno (free tier), and Pixabay/Reganati tracks stay ignored:
# their licences forbid redistributing the raw file (see CREDITS.md).
!apps/rounding-numbers/src/assets/music/chill-track-2-treblo.ogg
!apps/rounding-numbers/src/assets/music/dark-and-ominus-treblo.ogg
!apps/rounding-numbers/src/assets/music/kawaii-treblo.ogg
!apps/rounding-numbers/src/assets/music/level-up-division-treblo.ogg
!apps/rounding-numbers/src/assets/music/track-2-treblo.ogg

# Vendored fonts are gitignored until credited in CREDITS.md (ADR 0007). Once a
# font's source + licence are recorded, force-add it (git add -f).
apps/rounding-numbers/public/fonts/*.woff2
apps/rounding-numbers/public/fonts/*.woff
apps/rounding-numbers/public/fonts/*.ttf
apps/rounding-numbers/public/fonts/*.otf

# Cleared — Press Start 2P (SIL OFL 1.1, see CREDITS.md + public/fonts/OFL.txt).
# OFL permits bundling/redistribution; the notice travels in OFL.txt (committed).
!apps/rounding-numbers/public/fonts/press-start-2p.woff2
.vercel
